<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.DiaAIA">

        <activity
            android:name=".Registro"
            android:exported="false" />
        <activity
            android:name=".MenuPrincipal"
            android:exported="false" />

        <!-- Rutinas -->
        <activity
            android:name=".GestionRutinas"
            android:exported="false" />
        <activity
            android:name=".CrearEditarRutina"
            android:exported="false" />
        <activity
            android:name=".SelectorEjercicios"
            android:exported="false" />

        <!-- Entrenamiento -->
        <activity
            android:name=".SeleccionRutina"
            android:exported="false" />
        <activity
            android:name=".SesionEntrenamiento"
            android:exported="false" />
        <activity
            android:name=".Entrenamiento"
            android:exported="false" />

        <!-- Nutricion -->
        <activity
            android:name=".Nutricion"
            android:exported="false" />
        <activity
            android:name=".SelectorAlimentos"
            android:exported="false" />

        <!-- IA e historial -->
        <activity
            android:name=".ConsejosIA"
            android:exported="false" />
        <activity
            android:name=".Historial"
            android:exported="false" />

        <!-- Perfil -->
        <activity
            android:name=".Perfil"
            android:exported="false" />

        <!-- Requisitos deseables -->
        <activity
            android:name=".Estadisticas"
            android:exported="false" />
        <activity
            android:name=".ExportarPDF"
            android:exported="false" />
        <activity
            android:name=".MisClientes"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/provider_paths" />
        </provider>

    </application>

</manifest>
