<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F9"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🤖 Asistente IA"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#4A148C"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Consejos basados en reglas deterministas"
            android:textSize="13sp"
            android:textColor="#757575"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp" />

        <!-- BLOQUE NUTRICIÓN -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🥗 Nutrición · Consumo de hoy"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvAnalisisIA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Calculando..."
                    android:textSize="13sp"
                    android:textColor="#424242"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvConsejoIA"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Analizando déficits..."
                    android:textSize="14sp"
                    android:textColor="#1A237E"
                    android:lineSpacingExtra="4dp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:id="@+id/llAlimentosRecomendados"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BLOQUE ENTRENO -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="14dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🏋️ Entrenamiento"
                    android:textStyle="bold"
                    android:textColor="#1565C0"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tvConsejoEntreno"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Analizando constancia..."
                    android:textSize="14sp"
                    android:textColor="#424242"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnCerrarIA"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="ENTENDIDO"
            android:backgroundTint="#4A148C"
            android:textColor="#FFFFFF"
            app:cornerRadius="10dp" />
    </LinearLayout>
</ScrollView>
