<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F4F7F9"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏋️ Elige rutina"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_gravity="center"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvVacioSeleccion"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No tienes rutinas creadas.\nPuedes entrenar en modo libre."
        android:gravity="center"
        android:textColor="#757575"
        android:padding="24dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSeleccionRutina"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnEntrenoLibre"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="ENTRENO LIBRE (sin rutina)"
        android:backgroundTint="#FF8F00"
        android:textColor="#FFFFFF"
        app:cornerRadius="8dp"
        android:layout_marginTop="10dp" />

    <Button
        android:id="@+id/btnVolverSeleccion"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:text="Volver"
        android:backgroundTint="#757575"
        android:textColor="#FFFFFF"
        app:cornerRadius="8dp"
        android:layout_marginTop="8dp" />

</LinearLayout>
