<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F7F9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📊 Gráficas de progreso"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#C62828"
            android:layout_gravity="center"
            android:layout_marginBottom="16dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1RM estimado (Epley)"
                    android:textStyle="bold"
                    android:textColor="#1565C0" />

                <Spinner
                    android:id="@+id/spEjercicioEstad"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/tvEjerciciosVacio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Aún no has registrado ningún ejercicio con peso."
                    android:gravity="center"
                    android:textColor="#9E9E9E"
                    android:padding="8dp"
                    android:visibility="gone" />

                <com.example.diaaia.ui.SimpleLineChart
                    android:id="@+id/chart1RM"
                    android:layout_width="match_parent"
                    android:layout_height="200dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Evolución peso corporal"
                    android:textStyle="bold"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="6dp" />

                <com.example.diaaia.ui.SimpleLineChart
                    android:id="@+id/chartPesoCorporal"
                    android:layout_width="match_parent"
                    android:layout_height="200dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="3dp"
            android:layout_marginBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calorías diarias"
                    android:textStyle="bold"
                    android:textColor="#E53935"
                    android:layout_marginBottom="6dp" />

                <com.example.diaaia.ui.SimpleLineChart
                    android:id="@+id/chartKcal"
                    android:layout_width="match_parent"
                    android:layout_height="200dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnVolverEstad"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="Volver"
            android:backgroundTint="#757575"
            android:textColor="#FFFFFF"
            app:cornerRadius="8dp" />
    </LinearLayout>
</ScrollView>
